# Barista PIN voor /staff (verander dit voor productie!)
STAFF_PIN=1234

# --- Supabase (productie-opslag) ---
# Zonder deze 2 vars valt de app terug op de lokale JSON-file store (lib/store-file.ts).
# Mét deze vars praat de app met Postgres (lib/store-supabase.ts).
# NEXT_PUBLIC_SUPABASE_URL=https://pwsuxyifsiqnvakgzgnp.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # SECRET — alleen server-side

# Anon key — niet strict nodig voor onze app (we lezen/schrijven server-side
# via service_role), maar handig om beschikbaar te hebben als we later
# direct client-side queries willen doen.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Apple Wallet (optioneel, voor latere fase) ---
# APPLE_PASS_TYPE_ID=pass.nl.coffeegarden.stempelkaart
# APPLE_TEAM_ID=ABCDE12345
# APPLE_WWDR_CERT="-----BEGIN CERTIFICATE-----\n..."
# APPLE_PASS_CERT="-----BEGIN CERTIFICATE-----\n..."
# APPLE_PASS_KEY="-----BEGIN PRIVATE KEY-----\n..."
# APPLE_PASS_KEY_PASSPHRASE=

# --- Google Wallet (optioneel, voor latere fase) ---
# GOOGLE_WALLET_ISSUER_ID=
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=
