# =========================================================
# REQUIRED voor productie
# =========================================================

# Secret voor de HMAC-roterende QR. Genereer met:
#   openssl rand -hex 32   (of: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Min. 16 chars. NIET commit'en.
QR_SIGNING_SECRET=

# Legacy gedeelde barista-PIN. Wordt alléén gebruikt totdat je 1+ per-barista
# accounts hebt aangemaakt via /staff/users.
STAFF_PIN=1234

# Hostnames die we accepteren voor Origin/Referer-checks (CSRF-defense).
# Comma-gescheiden; alleen op productie strictly enforced.
# bv: TRUSTED_ORIGINS=stempel.coffeegarden.nl,coffeegarden.nl
TRUSTED_ORIGINS=

# =========================================================
# Supabase (productie-opslag)
# =========================================================

# Zonder deze 2 vars valt de app terug op de lokale JSON-file store (lib/store-file.ts).
# Mét deze vars praat de app met Postgres (lib/store-supabase.ts).
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # SECRET — alleen server-side
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# =========================================================
# Push (VAPID) + Cron
# =========================================================

# Genereer met: node scripts/gen-vapid.mjs
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:info@coffeegarden.nl
# CRON_SECRET=

# =========================================================
# Stempelkaart-config (alle defaults staan in lib/config.ts)
# =========================================================

# Aantal stempels voor een gratis drankje. Default 7.
# STAMPS_FOR_REWARD=7

# Geeft elke nieuwe klant direct 1 gratis stempel. Default aan.
# WELCOME_BONUS_STAMP=true

# Idempotency: max 1 stempel per X seconden per klant. Default 30.
# STAMP_COOLDOWN_SEC=30

# QR-token TTL. Customer-QR roteert; barista accepteert tokens binnen X sec. Default 60.
# QR_TOKEN_TTL_SEC=60

# Window waarin een barista een stempel kan undo'en. Default 60 sec.
# UNDO_WINDOW_SEC=60

# Login rate-limit: max N mispogingen / 10 min, lockout 5 min. 0 = uit.
# LOGIN_RATE_LIMIT=5
# LOGIN_LOCKOUT_SEC=300

# Bewaartermijn voor inactieve klanten (dagen). 0 = nooit auto-deleten.
# INACTIVE_RETENTION_DAYS=365

# Sta de legacy cg:cust:<uuid> QR-tokens toe? Default true (backwards-compat).
# Zet op false zodra alle bestaande klanten een rotating-QR hebben.
# LEGACY_QR_ALLOWED=true

# =========================================================
# E-mail (verificatie + double opt-in)
# =========================================================

# Resend.com — gratis tier voldoende. Laat leeg = mails worden alleen
# gelogd naar console (handig voor dev).
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=Coffee Garden <noreply@coffeegarden.nl>

# Publieke base-URL voor links in mails (verify-links etc.). Vercel zet
# VERCEL_URL automatisch; voor custom domein zet je 'm hier.
# NEXT_PUBLIC_BASE_URL=https://stempel.coffeegarden.nl

# Contact-e-mail die op /privacy wordt getoond.
# NEXT_PUBLIC_PRIVACY_CONTACT=info@coffeegarden.nl

# =========================================================
# Analytics (Plausible — optioneel, AVG-vriendelijk)
# =========================================================

# Leeg = analytics uit (geen script geladen).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=stempel.coffeegarden.nl
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# =========================================================
# Error monitoring (Sentry — optioneel)
# =========================================================

# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxx.ingest.sentry.io/yyy

# =========================================================
# Apple Wallet (optioneel — voor latere fase)
# =========================================================
# APPLE_PASS_TYPE_ID=pass.nl.coffeegarden.stempelkaart
# APPLE_TEAM_ID=ABCDE12345
# APPLE_WWDR_CERT="-----BEGIN CERTIFICATE-----\n..."
# APPLE_PASS_CERT="-----BEGIN CERTIFICATE-----\n..."
# APPLE_PASS_KEY="-----BEGIN PRIVATE KEY-----\n..."
# APPLE_PASS_KEY_PASSPHRASE=

# =========================================================
# Google Wallet (optioneel — gratis)
# =========================================================
# GOOGLE_WALLET_ISSUER_ID=
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=
